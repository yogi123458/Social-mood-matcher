# Social Mood Matcher - Environment Configuration Template
# Copy this file to .env and fill in your values

# Debug Settings
DEBUG=False
LOG_LEVEL=INFO

# Model Cache Directory (optional - defaults to ./models_cache)
MODEL_CACHE_DIR=./models_cache

# Google Gemini API Key (REQUIRED for Gemini features)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional API Keys (for future cloud model integration)
# OPENAI_API_KEY=your_openai_api_key_here
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# TWITTER_API_KEY=your_twitter_api_key_here

# Device Configuration (cpu or cuda)
# DEVICE=cpu

# AI Model Selection (local or gemini)
AI_MODEL=gemini
